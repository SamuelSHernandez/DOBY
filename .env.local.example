# Copy to `.env.local` and fill in values from your Supabase project
# (Project Settings → API). Both are safe to expose in a static client
# bundle: the publishable key only grants access guarded by Row Level
# Security.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
