# Copy to `.env.local` and fill in values from your Supabase project
# (Project Settings → API). Both are safe to expose in a static client
# bundle: the anon key only grants access guarded by Row Level Security.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
